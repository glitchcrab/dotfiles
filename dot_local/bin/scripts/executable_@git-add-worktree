#!/usr/bin/env bash

set -e
set -u
set -o pipefail

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <branch-name>"
    exit 1
fi

export DISPLAY=:0

repo=${PWD##*/}
branch=${1}
escapedBranch=$(echo "${branch//\//-}")

git worktree add "../_worktrees/${repo}/${escapedBranch}" -b "${branch}"

xclip -loops 1 -selection clipboard <<< "../_worktrees/${repo}/${escapedBranch}"
echo "[INFO] Worktree available at: ../_worktrees/${repo}/${escapedBranch}"
